{
  "name": "markdown-magic-version-badge",
  "version": "2.0.0",
  "description": "Version badge via Markdown Magic",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "test": "vitest run",
    "docs": "node example.js && prettier --write README.md",
    "prepublishOnly": "npm run docs",
    "format": "prettier --write ."
  },
  "prettier": {
    "singleQuote": true
  },
  "keywords": [
    "markdown-magic",
    "version Badge",
    "plugin"
  ],
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "license": "MIT",
  "devDependencies": {
    "markdown-magic": "^4.0.0",
    "prettier": "^3.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "markdown-magic": "^4"
  },
  "dependencies": {
    "find-up": "^8.0.0",
    "semver": "^7.0.0"
  }
}
